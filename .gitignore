# Segredos e configuração local
.env

# Vector store persistido (regenerado pelo ingest.py)
chroma_db/

# Ambiente virtual Python
venv/
.venv/
env/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# Dados (opcional — pode versionar os PDFs/DOCX se preferir)
# data/

# Streamlit cache
.streamlit/secrets.toml

# Modelos baixados pelo sentence-transformers (cache local)
# ~/.cache/huggingface/ — já fora do projeto, não precisa de .gitignore

# IDEs
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# macOS
.DS_Store

# Logs
*.log
logs/

# Jupyter (se usar para exploração)
.ipynb_checkpoints/
