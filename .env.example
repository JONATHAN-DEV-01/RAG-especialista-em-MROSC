# =====================================================================
# .env.example — Variáveis de ambiente do RAG Jurídico MROSC
#
# INSTRUÇÕES:
#   1. Copie este arquivo para ".env":  cp .env.example .env
#   2. Preencha os valores marcados com SUBSTITUA_AQUI_SE_FOR_USAR_*
#   3. Nunca versione o arquivo ".env" — ele já está no .gitignore
# =====================================================================

# ------------------------------------------------------------------
# Provedor de LLM — escolha UMA das opções abaixo
# Padrão: "ollama" (local, sem chave, sem internet)
# ------------------------------------------------------------------
LLM_PROVIDER=ollama    # opções: ollama | groq | gemini

# ------------------------------------------------------------------
# OLLAMA (padrão — 100% local, sem chave, sem limite)
# Certifique-se de que o Ollama está rodando: ollama serve
# E de que o modelo foi baixado:              ollama pull llama3.1:8b
# ------------------------------------------------------------------
OLLAMA_MODEL=llama3.1:8b          # ajuste para o modelo que você tiver baixado
OLLAMA_BASE_URL=http://localhost:11434   # TODO(usuário): ajuste se necessário

# ------------------------------------------------------------------
# GROQ (opcional — free tier, exige chave)
# Obtenha sua chave gratuita em: https://console.groq.com
# ------------------------------------------------------------------
GROQ_API_KEY=SUBSTITUA_AQUI_SE_FOR_USAR_GROQ
GROQ_MODEL=llama3-8b-8192         # modelos free: llama3-8b-8192, mixtral-8x7b-32768

# ------------------------------------------------------------------
# GOOGLE GEMINI (opcional — free tier, exige chave)
# Obtenha sua chave gratuita em: https://aistudio.google.com/app/apikey
# ------------------------------------------------------------------
GOOGLE_API_KEY=SUBSTITUA_AQUI_SE_FOR_USAR_GEMINI
GEMINI_MODEL=gemini-1.5-flash     # modelo gratuito com limites generosos

# ------------------------------------------------------------------
# Configurações do pipeline
# ------------------------------------------------------------------
CHROMA_PERSIST_DIR=./chroma_db    # TODO(usuário): ajuste se necessário
CHROMA_COLLECTION=mrosc_juridico  # TODO(usuário): ajuste se necessário
EMBEDDING_MODEL=intfloat/multilingual-e5-large  # ou: sentence-transformers/paraphrase-multilingual-mpnet-base-v2
